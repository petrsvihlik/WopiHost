<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WopiHost.Validator</title>
    <link rel="stylesheet" href="https://unpkg.com/marx-css/css/marx.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="https://github.com/petrsvihlik/WopiHost">GitHub</a></li>
            <li><a href="https://www.paypal.me/Svihlik">Donate</a></li>
        </ul>
    </nav>
    <header></header>
    <main>
        <section>
            <h1>WopiHost - Validator</h1>
            @RenderBody()
        </section>
    </main>
    <footer>
        <p>&copy; @DateTime.Now.Year - WopiHost.Validator - <a href="https://github.com/petrsvihlik/WopiHost" target="_blank" rel="noopener">GitHub</a></p>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
