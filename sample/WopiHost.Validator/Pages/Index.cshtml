@page
@using WopiHost.Discovery.Enumerations
@model IndexModel

<nav class="breadcrumb" aria-label="breadcrumb">
    <ol>
        <li><a asp-page="/Index">Root</a></li>
        @foreach (var part in Model.BreadcrumbParts)
        {
            <li><a href="@part.Url">@part.Name</a></li>
        }
        <li class="current" aria-current="page">@Model.ContainerName</li>
    </ol>
</nav>

<table class="files">
    <thead>
        <tr>
            <th class="col-icon">Type</th>
            <th>Name</th>
            <th class="col-date">Modified</th>
            <th class="col-size">Size</th>
            <th class="col-actions">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var container in Model.Containers)
        {
            <tr>
                <td class="col-icon">&#128193;</td>
                <td>
                    <a asp-page="/Index"
                       asp-route-ContainerId="@container.ContainerId"
                       asp-route-ParentContainerId="@(container.Name == ".." ? "" : Model.ContainerId)">
                        @container.Name
                    </a>
                </td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
        }

        @foreach (var file in Model.Files)
        {
            <tr>
                <td class="col-icon"><img src="@file.IconUri" alt="" /></td>
                <td>
                    @if (file.SupportsView)
                    {
                        <a asp-page="HostPage"
                           asp-route-FileId="@file.FileId"
                           asp-route-WopiAction="@WopiActionEnum.View"
                           title="View">@file.FileName</a>
                    }
                    else
                    {
                        @file.FileName
                    }
                </td>
                <td class="col-date">@file.LastModified.ToString("yyyy-MM-dd HH:mm")</td>
                <td class="col-size">@file.FormattedSize</td>
                <td class="col-actions">
                    @* See WopiHost.Web/Views/Home/Index.cshtml for the rationale on these
                       glyphs (🔍 U+1F50D + VS-15 / 🖉 U+1F589). *@
                    <a title="View"
                       asp-page="HostPage"
                       asp-route-FileId="@file.FileId"
                       asp-route-WopiAction="@WopiActionEnum.View"
                       class="@(file.SupportsView ? "" : "disabledIcon")">&#128269;&#65038;</a>
                    <a title="Edit"
                       asp-page="HostPage"
                       asp-route-FileId="@file.FileId"
                       asp-route-WopiAction="@WopiActionEnum.Edit"
                       class="@(file.SupportsEdit ? "" : "disabledIcon")">&#128393;</a>
                </td>
            </tr>
        }

        @if (Model.Containers.Count == 0 && Model.Files.Count == 0)
        {
            <tr><td colspan="5" class="empty">This container is empty.</td></tr>
        }
    </tbody>
</table>
