@* Router for the OIDC frontend. Mirrors WopiHost.Web/Routes.razor — plain RouteView is fine
   for static SSR; page-level [Authorize] metadata is enforced by app.UseAuthorization()
   ahead of component rendering, so no AuthorizeRouteView / CascadingAuthenticationState
   ceremony is needed here. *@

<Router AppAssembly="@typeof(Routes).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Layout.MainLayout)">
            <h2 class="text-danger">Page not found</h2>
            <p>The requested page does not exist on this WOPI host frontend.</p>
            <a href="/">Return to Home</a>
        </LayoutView>
    </NotFound>
</Router>
