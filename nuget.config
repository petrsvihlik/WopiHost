<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
		<!-- Microsoft.CobaltCore is published as a private package from
		     petrsvihlik/Microsoft.CobaltCore. GitHub Packages requires auth even for
		     read; the COBALT_PACKAGES_TOKEN env var is a fine-grained PAT scoped to
		     the Microsoft.CobaltCore repo with the `Packages: Read` permission. -->
		<add key="cobalt" value="https://nuget.pkg.github.com/petrsvihlik/index.json" />
	</packageSources>
	<packageSourceCredentials>
		<cobalt>
			<add key="Username" value="petrsvihlik" />
			<add key="ClearTextPassword" value="%COBALT_PACKAGES_TOKEN%" />
		</cobalt>
	</packageSourceCredentials>
	<packageSourceMapping>
		<packageSource key="nuget.org">
			<package pattern="*" />
		</packageSource>
		<packageSource key="cobalt">
			<package pattern="Microsoft.CobaltCore" />
		</packageSource>
	</packageSourceMapping>
</configuration>